      "source": [
        "import re\n",
        "\n",
        "def clean_text(text):\n",
        "    text = re.sub(r'[^a-zA-Z0-9\\s]', '', text)\n",
        "    return text.lower()\n",
        "\n",
        "def tokenize(tokenizer, text):\n",
        "    return tokenizer(text, padding='max_length', truncation=True, max_length=64, return_tensors='pt')"
      ]
    }
  ]
}