      "source": [
        "import pandas as pd\n",
        "\n",
        "def load_data(path):\n",
        "    df = pd.read_csv(path)\n",
        "    return df\n",
        "\n",
        "def split_data(df):\n",
        "    train = df.sample(frac=0.7)\n",
        "    val = df.drop(train.index).sample(frac=0.5)\n",
        "    test = df.drop(train.index).drop(val.index)\n",
        "    return train, val, test"
      ]
    }
  ]
}