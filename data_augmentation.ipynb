      "source": [
        "import random\n",
        "\n",
        "def add_noise(text):\n",
        "    words = text.split()\n",
        "    if len(words) > 2:\n",
        "        idx = random.randint(0, len(words)-1)\n",
        "        words[idx] = words[idx][::-1]\n",
        "    return \" \".join(words)"
      ]
    }
  ]
}