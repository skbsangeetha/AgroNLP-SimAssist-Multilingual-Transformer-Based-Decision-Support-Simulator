      "source": [
        "import shap\n",
        "\n",
        "class ShapExplainer:\n",
        "    def __init__(self, model):\n",
        "        self.model = model\n",
        "\n",
        "    def explain(self, data):\n",
        "        explainer = shap.Explainer(self.model)\n",
        "        shap_values = explainer(data)\n",
        "        return shap_values"
      ]
    }
  ]
}